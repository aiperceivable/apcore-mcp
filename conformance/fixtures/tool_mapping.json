{
  "description": "Standard mapping from apcore Module to MCP Tool (Algorithm M01)",
  "test_cases": [
    {
      "id": "basic_module_mapping",
      "input_module": {
        "module_id": "executor.email.send_email",
        "description": "Send an email via SMTP",
        "input_schema": {
          "type": "object",
          "properties": {
            "to": { "type": "string" },
            "subject": { "type": "string" }
          },
          "required": ["to"]
        },
        "annotations": {
          "readonly": false,
          "cacheable": false
        }
      },
      "expected_mcp_tool": {
        "name": "executor-email-send_email",
        "description": "Send an email via SMTP",
        "inputSchema": {
          "type": "object",
          "properties": {
            "to": { "type": "string" },
            "subject": { "type": "string" }
          },
          "required": ["to"],
          "additionalProperties": false
        },
        "annotations": {
          "cacheable": false
        }
      }
    },
    {
      "id": "llm_description_priority",
      "input_module": {
        "module_id": "auth.login",
        "description": "Human description",
        "input_schema": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "description": "Short desc",
              "x-llm-description": "Long AI-specific description of the token"
            }
          }
        }
      },
      "expected_mcp_tool": {
        "name": "auth-login",
        "description": "Human description",
        "inputSchema": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "description": "Long AI-specific description of the token"
            }
          }
        }
      }
    },
    {
      "id": "strip_x_extensions",
      "input_module": {
        "module_id": "data.query",
        "input_schema": {
          "type": "object",
          "properties": {
            "sql": {
              "type": "string",
              "x-sensitive": true,
              "x-internal-flag": "secret"
            }
          }
        }
      },
      "expected_mcp_tool": {
        "name": "data-query",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sql": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "id": "redacted_output_sensitive_field",
      "description": "Output redaction replaces x-sensitive field values with REDACTED (F-038)",
      "input_module": {
        "module_id": "auth.get_token",
        "input_schema": {
          "type": "object",
          "properties": {
            "username": { "type": "string" }
          }
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "token": { "type": "string", "x-sensitive": true },
            "expires_at": { "type": "string" }
          }
        }
      },
      "test_output": {
        "token": "secret-jwt-token-123",
        "expires_at": "2026-04-06T12:00:00Z"
      },
      "expected_redacted_output": {
        "token": "***REDACTED***",
        "expires_at": "2026-04-06T12:00:00Z"
      }
    },
    {
      "id": "extra_annotation_mcp_prefix_passthrough",
      "description": "mcp_ prefixed keys from annotations.extra flow to tool description (F-041)",
      "input_module": {
        "module_id": "image.resize",
        "description": "Resize an image",
        "input_schema": {
          "type": "object",
          "properties": {
            "width": { "type": "integer" }
          }
        },
        "annotations": {
          "readonly": false,
          "extra": {
            "mcp_category": "image",
            "mcp_cost": "high",
            "internal_flag": "ignored"
          }
        }
      },
      "expected_description_contains": ["category: image", "cost: high"],
      "expected_description_not_contains": ["internal_flag", "ignored"]
    }
  ]
}
